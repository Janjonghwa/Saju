generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  admin
}

enum ThemeType {
  basic
  daily
  yearly
  spouse
  job
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String         @unique
  emailVerified DateTime?
  image         String?
  role          UserRole       @default(user)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  accounts      Account[]
  sessions      Session[]
  birthProfiles BirthProfile[]
  reports       Report[]
  payments      Payment[]
  auditLogs     AuditLog[]
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
  REFUNDED
}

model Payment {
  id          String        @id @default(cuid())
  userId      String
  orderId     String        @unique
  amount      Int
  status      PaymentStatus @default(PENDING)
  provider    String
  productName String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([orderId])
}

model BirthProfile {
  id           String    @id @default(cuid())
  userId       String
  calendarType String
  isLeapMonth  Boolean
  birthDate    String
  birthTime    String
  gender       String
  timezone     String    @default("Asia/Seoul")
  label        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  reports      Report[]

  @@index([userId])
}

model Report {
  id             String        @id @default(cuid())
  userId         String
  birthProfileId String
  theme          ThemeType
  targetYear     Int?
  summary        String
  score          Int?
  tags           Json
  result         Json
  createdAt      DateTime      @default(now())
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  birthProfile   BirthProfile  @relation(fields: [birthProfileId], references: [id], onDelete: Cascade)
  logs           ReportLog[]

  @@index([userId])
  @@index([birthProfileId])
  @@index([theme])
}

model InterpretationMessage {
  id        String   @id @default(cuid())
  theme     String
  category  String
  tag       String
  title     String
  content   String
  priority  Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([theme, category, tag, priority])
}

model ReportLog {
  id             String   @id @default(cuid())
  reportId       String
  requestPayload Json
  generatedTags  Json
  createdAt      DateTime @default(now())
  report         Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  action      String
  entityType  String
  entityId    String
  beforeValue Json?
  afterValue  Json?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entityType, entityId])
}

// NextAuth core models
model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}
